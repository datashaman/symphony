# Symphony Environment Variables
# Copy this file to .env and fill in your values.
# These are referenced in WORKFLOW.md using $VAR or ${VAR} syntax.

# ── GitHub Tracker ──────────────────────────────────────────────
# Personal access token with repo scope (or fine-grained with Issues read/write)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Jira Tracker ────────────────────────────────────────────────
# Jira Cloud instance base URL (no trailing slash)
JIRA_BASE_URL=https://your-domain.atlassian.net

# Email address associated with the Jira account
JIRA_EMAIL=you@example.com

# Jira API token (generate at https://id.atlassian.com/manage-profile/security/api-tokens)
JIRA_API_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx
