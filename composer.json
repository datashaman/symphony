{
    "name": "datashaman/symphony",
    "description": "PHP implementation of the Symphony orchestration daemon for coding agents.",
    "keywords": ["symphony", "orchestrator", "coding-agent", "cli", "daemon"],
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "datashaman"
        }
    ],
    "require": {
        "php": "^8.4",
        "ext-pcntl": "*",
        "ext-posix": "*",
        "guzzlehttp/guzzle": "^7.0",
        "illuminate/http": "^12.17",
        "illuminate/log": "^12.17",
        "laravel-zero/framework": "^12.0.2",
        "laravel-zero/phar-updater": "^1.4",
        "monolog/monolog": "^3.10",
        "symfony/yaml": "^8.0",
        "twig/twig": "^3.24"
    },
    "require-dev": {
        "laravel/pint": "^1.25.1",
        "mockery/mockery": "^1.6.12",
        "pestphp/pest": "^3.8.4|^4.1.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "config": {
        "preferred-install": "dist",
        "sort-packages": true,
        "optimize-autoloader": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true,
    "bin": ["application"]
}
